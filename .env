# RIFT EFFECT - Environment Configuration
# Copy this to .env and adjust values as needed

# App Settings
APP_NAME=RIFT EFFECT
APP_VERSION=1.0.0
ENV=development
DEBUG=true
DOMAIN=localhost
FRONTEND_URL=http://localhost:8000

# Database (default from docker-compose)
DATABASE_URL=postgresql+asyncpg://rift:riftpass@db:5432/rift
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Redis (default from docker-compose)
REDIS_URL=redis://:redispass@redis:6379/0
CELERY_BROKER=redis://:redispass@redis:6379/1
CELERY_BACKEND=redis://:redispass@redis:6379/2

# Storage (local by default - no R2 needed for testing)
STORAGE_BACKEND=local
STORAGE_ROOT=/data/storage

# JWT - generate a secure secret for production
JWT_SECRET=dev-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=30

# Stripe - leave empty for testing (billing will be disabled)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_STUDIO=
PRICE_PER_VIDEO_CENTS=2500

# Plan Limits
PLAN_STARTER_RENDERS=10
PLAN_PRO_RENDERS=50
PLAN_STUDIO_RENDER=200

# Email (optional - leave empty to disable)
SENDGRID_API_KEY=
EMAIL_FROM=noreply@rifteffect.com
EMAIL_FROM_NAME=RIFT EFFECT

# Upload Limits
MAX_UPLOAD_BYTES=4294967296
MAX_VIDEO_SECONDS=600.0
OUTPUT_RETAIN_DAYS=7
UPLOAD_RETAIN_HOURS=48

# Rendering
RENDER_TIMEOUT=7200
PREVIEW_TIMEOUT=90
GPU_MEMORY_FRACTION=0.85

# CORS
CORS_ORIGINS=["http://localhost","http://localhost:8000"]
TRUSTED_HOSTS=["*"]

# Monitoring (optional)
SENTRY_DSN=

# Celery Flower UI
FLOWER_USER=admin
FLOWER_PASS=flowerpass
